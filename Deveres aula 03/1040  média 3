#include <stdio.h>
 
int main() {
 
  double n1,n2,n3,n4, media, exame; 
 
 scanf("%lf %lf", &n1,&n2);
 scanf("%lf %lf", &n3,&n4);
 
 media = ((n1*2.0)+(n2*3.0)+(n3*4.0)+(n4*1.0)) /10.0;
 
  printf("Media: ");
 printf("%.1lf\n", media);
 
 if (media >=5.0 && media <= 6.9 ){
     printf("Aluno em exame.");
     scanf("%lf\n",&exame);
     printf("\nNota do exame: ");
     printf("%.1lf\n", exame);
     
     media = (media + exame)/2.0;
     
     if(media >= 5.0){
         printf("Aluno aprovado.");
         printf("\nMedia final: ");
         printf("%.1lf\n", media);
     }
     else if (media <=4.9){
         printf("Aluno reprovado.");
         printf("\nMedia final: ");
         printf("%.1lf\n", media);
     }
      }
      
  else if (media >=7.0){
     printf("Aluno aprovado.\n");
      }
      
 else if (media <5.0){
     printf("Aluno reprovado.\n");
      }
 

    return 0;
}
